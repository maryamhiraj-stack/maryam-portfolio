      transform: translateY(-3px);
      box-shadow: 0 15px 30px rgba(59,130,246,0.4);
    }
    .btn-outline {
      border: 1px solid #38bdf8;
      color: #38bdf8;
      background: transparent;
    }
    .btn-outline:hover {
      background: rgba(56,189,248,0.1);
      transform: translateY(-3px);
    }
