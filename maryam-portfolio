    }

    body {
      background: #0a0c10;
      color: #eef2ff;
      line-height: 1.6;
      scroll-behavior: smooth;
    }

    /* animated gradient background - dark theme */
    body::before {
      content: "";
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: radial-gradient(circle at 20% 30%, rgba(79, 70, 229, 0.15) 0%, rgba(6, 182, 212, 0.05) 50%, transparent 80%);
      pointer-events: none;
      z-index: -2;
    }

    body::after {
      content: "";
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background-image: 
        linear-gradient(rgba(56, 189, 248, 0.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(56, 189, 248, 0.03) 1px, transparent 1px);
      background-size: 40px 40px;
      pointer-events: none;
      z-index: -1;
    }

    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 2rem;
    }

    /* navbar - glassmorphism dark */
    .navbar {
      position: sticky;
      top: 0;
      backdrop-filter: blur(16px);
      background: rgba(10, 12, 16, 0.85);
      border-bottom: 1px solid rgba(56, 189, 248, 0.2);
      z-index: 100;
      padding: 1rem 0;
