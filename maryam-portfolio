      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }
    .hero p {
      font-size: 1.2rem;
      margin: 1.5rem 0 2rem;
      color: #a0b3d9;
      max-width: 600px;
    }
    .btn-group {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
    }
    .btn {
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
      padding: 0.8rem 1.8rem;
      border-radius: 40px;
      font-weight: 600;
      text-decoration: none;
      transition: 0.2s;
      border: 1px solid transparent;
      cursor: pointer;
      font-size: 0.95rem;
